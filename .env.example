OPENAI_NEXT_API_KEY=replace-with-your-key
OPENAI_NEXT_BASE_URL=https://api.openai-next.com
OPENAI_NEXT_MODEL=claude-sonnet-5
OPENAI_NEXT_ANTHROPIC_VERSION=2023-06-01
OPENAI_NEXT_MAX_TOKENS=4096
OPENAI_NEXT_TEMPERATURE=0
OPENAI_NEXT_THINKING=disabled
