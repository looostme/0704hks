OPENAI_NEXT_ASR_TIMEOUT=90
OPENAI_NEXT_ASR_MAX_AUDIO_MB=24
MEDIA_MAX_IMAGE_MB=10
APP_ACCESS_TOKEN=replace-with-random-access-token
